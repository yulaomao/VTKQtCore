{
  "connections": [
    {
      "connectionId": "conn_main",
      "host": "127.0.0.1",
      "port": 6379,
      "db": 0,
      "pollIntervalMs": 16,
      "pollingKeyGroups": [
        { "module": "params",    "keys": ["state.params.latest"] },
        { "module": "pointpick", "keys": ["state.pointpick.latest"] },
        { "module": "planning",  "keys": ["state.planning.latest"] }
      ],
      "subscriptionChannels": [
        { "channel": "state.params",     "module": "params"     },
        { "channel": "state.pointpick",  "module": "pointpick"  },
        { "channel": "state.planning",   "module": "planning"   }
      ]
    },
    {
      "connectionId": "conn_nav",
      "host": "127.0.0.1",
      "port": 6379,
      "db": 1,
      "pollIntervalMs": 16,
      "pollingKeyGroups": [
        {
          "module": "navigation",
          "keys": ["state.navigation.latest"]
        },
        {
          "module": "global",
          "keys": [
            "demo:navigation:transform:world",
            "demo:navigation:transform:reference",
            "demo:navigation:transform:patient",
            "demo:navigation:transform:instrument",
            "demo:navigation:transform:guide",
            "demo:navigation:transform:tip"
          ]
        }
      ],
      "subscriptionChannels": [
        { "channel": "state.navigation", "module": "navigation" }
      ]
    }
  ],
  "globalDispatchRules": [
    {
      "keyPattern":   "demo:navigation:transform:*",
      "targetModule": "navigation",
      "groupName":    "transforms"
    }
  ],
  "modules": [
    {
      "moduleId": "params",
      "defaultConnectionId": "conn_main",
      "nestedMapStructure": {}
    },
    {
      "moduleId": "pointpick",
      "defaultConnectionId": "conn_main",
      "nestedMapStructure": {}
    },
    {
      "moduleId": "planning",
      "defaultConnectionId": "conn_main",
      "nestedMapStructure": {}
    },
    {
      "moduleId": "navigation",
      "defaultConnectionId": "conn_nav",
      "nestedMapStructure": {
        "state": ["state.navigation.latest"]
      }
    }
  ]
}
